ASSISTANT_HAS_OWN_NUMBER=

# Google Calendar MCP server — run /tmp/get-gcal-token.mjs once to populate these
GCAL_CLIENT_ID=         # GCP → APIs & Services → Credentials → OAuth 2.0 Client ID
GCAL_CLIENT_SECRET=     # Same GCP OAuth client
GCAL_REFRESH_TOKEN=     # Output by get-gcal-token.mjs after browser auth
GCAL_MCP_PORT=3020      # Port the MCP server listens on
